#!/usr/bin/env bash

#==================================================
# SETUP DEBUGGING AND SAFETY FLAGS
#==================================================
set -o errexit  # exit script on error
set -o pipefail # exit when a script in a pipeline fails
set -o nounset  # don't allow unset variables

# Check jira-cli is installed
if ! [[ -x "$(command -v jira)" ]]; then
  echo "jira-cli is not installed. Please install it by running './system-installer' in your dotfiles repo"
  exit 1
fi

# Source secrets file
source $HOME/.bash_secrets

# Validate JIRA API token is available
if [[ -z "${JIRA_API_TOKEN:-}" ]]; then
    echo "ERROR: JIRA_API_TOKEN is not set in ~/.bash_secrets"
    echo ""
    echo "Please add the following to ~/.bash_secrets:"
    echo "  export JIRA_API_TOKEN='your-token-here'"
    echo ""
    echo "Generate a token at: https://id.atlassian.com/manage-profile/security/api-tokens"
    exit 1
fi

# Export the token for jira-cli to use
export JIRA_API_TOKEN

# Get current active sprint with error handling
echo "Checking for active sprint..."
current_sprint_id=$(jira sprint list --plain --state active --no-headers 2>&1 | head -n 1 | awk '{print $1}')

# Get jira user
jira_user=$(jira me)

# Prompt for issue summary and description
echo ""
read -p "Summary: " summary
read -p "Description (optional): " description

echo ""
echo "Creating hotfix issue..."
echo "  Assignee: $jira_user"
echo "  Reporter: $jira_user"
echo "  Priority: High"
echo "  Story Points: 2"
echo "  Summary: $summary"

# Build the jira issue create command
create_args=(
	--assignee "$jira_user"
	--reporter "$jira_user"
	--priority "High"
	--type "Hotfix"
	--summary "$summary"
	--custom story-points=2
	--no-input
)

# Add description if provided
if [[ -n "$description" ]]; then
	create_args+=(--body "$description")
fi

# Validate sprint ID and prompt user if missing
if [[ -z "$current_sprint_id" ]]; then
    echo ""
    echo "⚠️  WARNING: No active sprint found."
    echo ""
    read -p "Do you want to create the hotfix without a sprint? (y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Exiting. Please activate a sprint and try again."
        exit 1
    fi
    echo "Creating hotfix without sprint assignment..."
elif [[ ! "$current_sprint_id" =~ ^[0-9]+$ ]]; then
    echo ""
    echo "⚠️  WARNING: Invalid sprint ID detected: '$current_sprint_id'"
    echo "Creating hotfix without sprint assignment..."
    current_sprint_id=""
else
    echo "  Sprint: $current_sprint_id"
    create_args+=(--custom sprint="$current_sprint_id")
fi

# Create the issue and capture output
if ! output=$(jira issue create "${create_args[@]}" 2>&1); then
    echo ""
    echo "ERROR: Failed to create Jira issue."
    echo "Output: $output"
    echo ""
    echo "Check that:"
    echo "  - Your JIRA_API_TOKEN is valid"
    echo "  - You have permission to create Hotfix issues in project DYN"
    echo "  - The jira-cli is properly configured (~/.config/.jira/.config.yml)"
    exit 1
fi

# Display the output to user
echo "$output"

# Extract issue key
issue_key=$(echo "$output" | grep -o 'DYN-[0-9]*$' | tail -n 1)

if [[ -z "$issue_key" ]]; then
    echo ""
    echo "ERROR: Failed to extract issue key from jira output."
    exit 1
fi

echo ""
echo "✓ Created issue: $issue_key"

# Move to "To Do" status
if ! jira issue move "$issue_key" "To Do" &>/dev/null; then
    echo "⚠️  WARNING: Failed to move issue to 'To Do' status."
    echo "You may need to move it manually in Jira."
else
    echo "✓ Moved issue to 'To Do' status"
fi

echo -e "\nChecking out branch for issue $issue_key..."

git jchk $issue_key
